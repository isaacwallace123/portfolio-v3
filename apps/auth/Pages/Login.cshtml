@page
@model LoginModel
@{
    ViewData["Title"] = "Sign in";
    var ret = Uri.EscapeDataString(Model.Dest);
}

@if (Model.SignedIn)
{
    @* Already signed in: this page is a turnstile, so offer the way through — not a form. *@
    <div class="card card--center pop-in">
        <span class="avatar" aria-hidden="true">
            @(((Model.DisplayName ?? Model.Email ?? "?").Substring(0, 1)).ToUpperInvariant())
        </span>
        <h1 class="card-title">You&apos;re signed in</h1>
        <p class="card-email">@Model.Email</p>
        <div class="stack">
            <a class="btn btn-primary" href="@Model.Dest">Continue</a>
            <form method="post" asp-page-handler="Logout">
                <input type="hidden" name="returnUrl" value="@Model.Dest" />
                <button type="submit" class="btn btn-ghost">Sign out</button>
            </form>
        </div>
        <p class="card-foot">
            Profile, sessions, and preferences live in the Settings menu on every site — this page only
            handles signing in and out.
        </p>
    </div>
}
else
{
    <div class="card pop-in">
        <h1 class="card-title card-title--lg">Sign in</h1>
        <p class="card-sub">
            One account for the whole network. New here? Signing in with a provider creates your account.
        </p>

        <div class="stack">
            @foreach (var provider in Model.Providers)
            {
                <a class="btn btn-provider" href="/auth/login/@provider.ToLowerInvariant()?returnUrl=@ret">
                    @if (provider == "Google")
                    {
                        <svg viewBox="0 0 24 24" class="glyph" aria-hidden="true">
                            <path fill="#4285F4" d="M23.06 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h6.2a5.3 5.3 0 0 1-2.3 3.48v2.89h3.72c2.18-2 3.44-4.96 3.44-8.38Z" />
                            <path fill="#34A853" d="M12 24c3.1 0 5.7-1.03 7.6-2.79l-3.72-2.89c-1.03.69-2.35 1.1-3.88 1.1-2.98 0-5.5-2.01-6.4-4.71H1.76v2.98A11.5 11.5 0 0 0 12 24Z" />
                            <path fill="#FBBC05" d="M5.6 14.71a6.9 6.9 0 0 1 0-4.42V7.31H1.76a11.5 11.5 0 0 0 0 10.38l3.84-2.98Z" />
                            <path fill="#EA4335" d="M12 4.77c1.68 0 3.19.58 4.38 1.72l3.29-3.29A11.5 11.5 0 0 0 1.76 7.31L5.6 10.3C6.5 7.58 9.02 4.77 12 4.77Z" />
                        </svg>
                    }
                    else if (provider == "GitHub")
                    {
                        <svg viewBox="0 0 24 24" class="glyph" aria-hidden="true" fill="currentColor">
                            <path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.46-2.3 1.2-3.1-.12-.3-.52-1.48.11-3.08 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.18 3.2-1.18.63 1.6.23 2.78.11 3.08.75.8 1.2 1.84 1.2 3.1 0 4.43-2.7 5.4-5.28 5.69.42.36.79 1.08.79 2.17v3.22c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z" />
                        </svg>
                    }
                    Continue with @provider
                </a>
            }

            @if (Model.Providers.Count == 0 && !Model.DevLoginEnabled)
            {
                <p class="card-sub">No sign-in providers are configured yet.</p>
            }
        </div>

        @if (Model.DevLoginEnabled)
        {
            @if (Model.Providers.Count > 0)
            {
                <div class="divider"><span></span>dev only<span></span></div>
            }
            <form method="post" asp-page-handler="DevLogin" class="stack">
                <input type="hidden" name="returnUrl" value="@Model.Dest" />
                <input class="field" type="email" name="email" required
                       placeholder="you@@example.com (dev login)" autocomplete="email" aria-label="Dev login email" />
                <button type="submit" class="btn btn-primary">Dev sign in</button>
            </form>
        }

        @if (Model.Error is not null)
        {
            <p class="error" role="alert">@Model.Error</p>
        }

        <p class="lock-note">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="4" y="10" width="16" height="10" rx="2" />
                <path d="M8 10V7a4 4 0 0 1 8 0v3" />
            </svg>
            No password stored — identity comes from your provider.
        </p>
    </div>
}
