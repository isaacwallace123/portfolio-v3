# Copy to `.env` (gitignored) and adjust. Every value has a working dev default.

# ── database ──────────────────────────────────────────────────────────────
POSTGRES_USER=iw
POSTGRES_PASSWORD=iw-dev-only
POSTGRES_DB=iw
POSTGRES_PORT=5432

# ── ports on your host ────────────────────────────────────────────────────
AUTH_SERVICE_PORT=5170
API_PORT=5180
WEB_PORT=3000
CYBERLAB_PORT=3001
ADMIN_PORT=3004

# ── app config ────────────────────────────────────────────────────────────
# Development keeps the cookie http-friendly; use Production only behind https.
API_ENV=Development
ADMIN_EMAIL=goosewal@gmail.com

# URLs the BROWSER uses (inlined into the client bundles at image build time).
# AUTH_API_URL is the dedicated auth service (sign-in/sessions/roles); API_URL is the general app API.
NEXT_PUBLIC_AUTH_API_URL=http://localhost:5170
NEXT_PUBLIC_API_URL=http://localhost:5180
NEXT_PUBLIC_HOME_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3004

# ── OAuth (optional locally) ──────────────────────────────────────────────
# Leave blank to use dev-login (email only, no password) in development. To exercise the real
# Google/GitHub flow locally, point OAuth apps at the AUTH SERVICE on :5170:
#   Google:  redirect URI  http://localhost:5170/signin-google
#            (one Google client can also hold the prod URI https://auth.isaacwallace.dev/signin-google)
#   GitHub:  callback URL  http://localhost:5170/signin-github
#            (GitHub allows ONE callback per app, so prod needs a SEPARATE app whose callback is
#             https://auth.isaacwallace.dev/signin-github)
# These are consumed only via `make up` (compose). NEVER commit real secrets — prod creds live in the
# sealed k8s secret (deploy/k8s/sealed-secret.yaml), not here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Where the cyberlab repo's web app lives, relative to this file.
CYBERLAB_DIR=../cyberlab/web
